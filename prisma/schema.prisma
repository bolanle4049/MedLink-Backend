generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Facility {
  id               String    @id @default(uuid())
  name             String
  type             String    // 'hospital' | 'clinic'
  location         String?
  avgResponseMin   Int       @default(30)
  doctors          Doctor[]
  patients         Patient[]
  episodes         Episode[]
}

model Doctor {
  id                 String      @id @default(uuid())
  facilityId         String
  facility           Facility    @relation(fields: [facilityId], references: [id])
  email              String      @unique
  passwordHash       String      @map("password_hash")
  fullName           String      @map("full_name")
  role               String
  mdcnLicense        String      @map("mdcn_license")
  isVerified         Boolean     @default(false) @map("is_verified")
  isActive           Boolean     @default(true) @map("is_active")
  mustResetPassword  Boolean     @default(true) @map("must_reset_password")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  episodes           Episode[]
  auditLogs          AuditLog[]

  @@map("doctors")
}

model RevokedToken {
  token     String   @id
  revokedAt DateTime @default(now()) @map("revoked_at")

  @@map("revoked_tokens")
}

model Contact {
  id               String               @id @default(uuid())
  waPhone          String               @unique @map("wa_phone")
  lastSeen         DateTime             @default(now()) @map("last_seen")
  consents         Consent[]
  episodes         Episode[]
  patientLinks     ContactPatientLink[]

  @@map("contacts")
}

model Patient {
  id                 String               @id @default(uuid())
  facilityId         String?              @map("facility_id")
  facility           Facility?            @relation(fields: [facilityId], references: [id])
  name               String
  dob                DateTime?
  sex                String
  facilityPatientId  String?              @map("facility_patient_id")
  contactLinks       ContactPatientLink[]
  episodes           Episode[]

  @@map("patients")
}

model ContactPatientLink {
  id           String   @id @default(uuid())
  contactId    String   @map("contact_id")
  patientId    String   @map("patient_id")
  verifyStatus String   @map("verify_status")
  contact      Contact  @relation(fields: [contactId], references: [id])
  patient      Patient  @relation(fields: [patientId], references: [id])

  @@map("contact_patient_links")
}

model Episode {
  id                   String                 @id @default(uuid())
  contactId            String                 @map("contact_id")
  contact              Contact                @relation(fields: [contactId], references: [id])
  patientId            String?                @map("patient_id")
  patient              Patient?               @relation(fields: [patientId], references: [id])
  facilityId           String?                @map("facility_id")
  facility             Facility?              @relation(fields: [facilityId], references: [id])
  doctorId             String?                @map("doctor_id")
  doctor               Doctor?                @relation(fields: [doctorId], references: [id])
  
  coverageCase         Int?                   @map("coverage_case") // 1, 2, or 3
  triageBand           String?                @map("triage_band") // 'critical', 'emergency', 'urgent', 'routine', 'non_urgent'
  isCritical           Boolean                @default(false) @map("is_critical")
  reporterRelationship String                 @map("reporter_relationship") // 'me', 'child', 'other_adult'
  subjectAge           Int?                   @map("subject_age")
  subjectSex           String?                @map("subject_sex")
  identityMismatch     Boolean                @default(false) @map("identity_mismatch")
  
  status               String                 // 'awaiting_consent', 'identifying', 'coverage', 'interviewing', 'queued', 'in_review', 'resolved', 'needs_visit', 'pending_followup'
  outcome              String?
  queuedAt             DateTime?              @map("queued_at")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  
  messages             Message[]
  observations         Observation[]
  hmoVerification      EnrolleeVerification?
  auditLogs            AuditLog[]

  @@map("episodes")
}

model Message {
  id             String        @id @default(uuid())
  episodeId      String        @map("episode_id")
  episode        Episode       @relation(fields: [episodeId], references: [id])
  direction      String        // 'inbound' | 'outbound'
  body           String
  waMessageId    String        @unique @map("wa_message_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  observations   Observation[]

  @@map("messages")
}

model Observation {
  id               String   @id @default(uuid())
  episodeId        String   @map("episode_id")
  episode          Episode  @relation(fields: [episodeId], references: [id])
  sourceMessageId  String   @map("source_message_id")
  message          Message  @relation(fields: [sourceMessageId], references: [id])
  code             String
  value            String
  sourceQuote      String   @map("source_quote")

  @@map("observations")
}

model EnrolleeVerification {
  id                 String   @id @default(uuid())
  episodeId          String   @unique @map("episode_id")
  episode            Episode  @relation(fields: [episodeId], references: [id])
  hmoId              String   @map("hmo_id")
  hmo                HMO      @relation(fields: [hmoId], references: [id])
  valid              Boolean
  enrolleeId         String   @map("enrollee_id")
  enrolleeName       String   @map("enrollee_name")
  planTier           String?  @map("plan_tier")
  homeFacilityId     String?  @map("home_facility_id")
  coverageStatus     String   @map("coverage_status")
  verificationMethod String   @map("verification_method") // 'api' | 'list' | 'manual'

  @@map("enrollee_verifications")
}

model HMO {
  id             String                 @id @default(uuid())
  name           String
  defaultMethod  String                 @map("default_method")
  verifications  EnrolleeVerification[]

  @@map("hmos")
}

model Consent {
  id         String   @id @default(uuid())
  contactId  String   @map("contact_id")
  contact    Contact  @relation(fields: [contactId], references: [id])
  scope      String
  grantedAt  DateTime @default(now()) @map("granted_at")

  @@map("consents")
}

model AuditLog {
  id         String   @id @default(uuid())
  episodeId  String   @map("episode_id")
  episode    Episode  @relation(fields: [episodeId], references: [id])
  doctorId   String?  @map("doctor_id")
  doctor     Doctor?  @relation(fields: [doctorId], references: [id])
  action     String
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
